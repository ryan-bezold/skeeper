# =============================================================================
# Skeeper Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables are REQUIRED unless marked optional.
# The app will refuse to start if any required variable is missing.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Runtime environment. Affects DB auto-sync and logging.
# Allowed values: development | staging | production
NODE_ENV=development

# Port the HTTP/WebSocket server listens on.
PORT=3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=skeeper
DATABASE_USER=skeeper
DATABASE_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins, or a single origin.
# In production set this to your frontend domain, e.g. https://skeeper.example.com
# OPTIONAL — defaults to http://localhost:5173
CORS_ORIGIN=http://localhost:5173
