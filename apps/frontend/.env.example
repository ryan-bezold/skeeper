# =============================================================================
# Skeeper Frontend — Environment Variables
# =============================================================================
# Copy this file to .env (development) or .env.production / .env.staging.
# Vite loads the file matching the current mode automatically.
# All VITE_* variables are inlined at build time.

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------

# Base URL for the backend REST API.
# In production set this to your backend domain, e.g. https://api.skeeper.example.com
VITE_API_URL=http://localhost:3000

# WebSocket server URL (same host as API, different scheme).
# In production: wss://api.skeeper.example.com
VITE_WS_URL=ws://localhost:3000

# -----------------------------------------------------------------------------
# Environment name (optional)
# -----------------------------------------------------------------------------

# Explicit environment label exposed as env.envName in the app.
# Allowed values: development | staging | production
# Defaults to Vite's MODE if omitted.
VITE_ENV=development
