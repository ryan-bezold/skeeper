# =============================================================================
# Skeeper Docker — Environment Variables
# =============================================================================
# Copy this file to .env.docker and fill in your values.
# Used by docker-compose.yml via env_file.

# Application
NODE_ENV=development
PORT=3000

# Database
POSTGRES_DB=skeeper
POSTGRES_USER=skeeper
POSTGRES_PASSWORD=skeeper_dev_password
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=skeeper
DATABASE_USER=skeeper
DATABASE_PASSWORD=skeeper_dev_password

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_ENV=development
